<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NexTalk</title>

    <script type="importmap"></script>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/private-chat.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/SignalRTask.styles.css" asp-append-version="true" />

</head>

<body>

    <header>

        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">

            <div class="container-fluid">

                <a class="navbar-brand"
                   asp-controller="Home"
                   asp-action="Index">

                    NexTalk

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse" id="navbarNav">

                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">

                                Home

                            </a>

                        </li>

                        @if (User.Identity!.IsAuthenticated)
                        {
                            <li class="nav-item">

                                <a class="nav-link"
                                   asp-controller="Friends"
                                   asp-action="Index">

                                    Friends

                                </a>

                            </li>

                            <li class="nav-item">

                                <a class="nav-link"
                                   asp-controller="Groups"
                                   asp-action="Index">

                                    Groups

                                </a>

                            </li>
                        }

                    </ul>

                    <partial name="_LoginPartial" />

                </div>

            </div>

        </nav>

    </header>

    <div class="container">

        <main role="main" class="pb-3">

            @RenderBody()

        </main>

    </div>

    <!-- Toast -->

    <div class="toast-container position-fixed bottom-0 end-0 p-3"
         style="z-index:9999">

        <div id="liveToast"
             class="toast"
             role="alert"
             data-bs-delay="5000">

            <div class="toast-header">

                <strong id="toastTitle"
                        class="me-auto">

                    Notification

                </strong>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="toast">
                </button>

            </div>

            <div id="toastBody"
                 class="toast-body">
            </div>

        </div>

    </div>

    <footer class="border-top footer text-muted">

        <div class="container">

            &copy; 2026 - NexTalk -

            <a asp-controller="Home"
               asp-action="Privacy">

                Privacy

            </a>

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>

        function showToast(title, body) {

            document.getElementById("toastTitle").innerHTML = title;

            document.getElementById("toastBody").innerHTML = body;

            let toast = new bootstrap.Toast(document.getElementById("liveToast"));

            toast.show();

        }

        const notificationConnection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

                notificationConnection.on("ReceiveNotification", function (id, title, content, url) {

            let currentPage = window.location.pathname.toLowerCase();

            if (currentPage === url.toLowerCase()) {

                return;

            }

            showToast(title, content);

            loadNotifications();

            loadUnreadCount();

        });

        notificationConnection.start();
        loadNotifications();
        loadUnreadCount();

        async function loadNotifications() 
        {

            let response = await fetch("/Chat/GetNotifications");

            let notifications = await response.json();

            let list = document.getElementById("notificationList");

            list.innerHTML = "";

            if (notifications.length === 0) {

                list.innerHTML = `
                    <li class="dropdown-item text-muted">
                        No notifications
                    </li>`;

                return;
            }

                    notifications.forEach(n => {

            list.innerHTML += `
                <li>
                    <a class="dropdown-item"
                       href="${n.url}"
                       onclick="markAsRead(${n.id})">

                        <strong>${n.title}</strong><br/>

                        <small>${n.content}</small>

                    </a>
                </li>`;

        });

        }
                async function loadUnreadCount() {

            let response = await fetch("/Chat/GetUnreadNotificationsCount");

            let count = await response.json();

            let badge = document.getElementById("notificationCount");

            if (count > 0) {

                badge.style.display = "";

                badge.innerHTML = count;

            }
            else {

                badge.style.display = "none";

            }

        }

                async function markAsRead(id) {

            await fetch("/Chat/MarkNotificationAsRead?id=" + id,
            {
                method: "POST"
            });

            loadUnreadCount();

        }

    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>