@model SignalRTask.ViewModels.Groups.GroupChatVM

@{
    ViewData["Title"] = Model.Room.Name;
}

<div class="chat-container">

    <div class="chat-header">

        <h4>@Model.Room.Name</h4>

        <a asp-action="Index"
           class="btn btn-light btn-sm">

            Back

        </a>

    </div>

    <div class="chat-body" id="chatBody">

        @foreach (var message in Model.Messages)
        {
            bool mine = message.SenderId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            <div class="message-row @(mine ? "my-message" : "friend-message")">

                <div class="message-box position-relative" id="msg-@message.Id">

                    @if (!mine)
                    {
                        <strong>@message.Sender.UserName?.Split('@')[0]</strong>
                        <br />
                    }

                    @if (mine && !message.IsDeleted)
                    {
                        <div class="dropdown position-absolute top-0 end-0">

                            <button class="btn btn-sm border-0 text-white"
                                    data-bs-toggle="dropdown">

                                ⋮

                            </button>

                            <ul class="dropdown-menu">

                                <li>

                                    <button class="dropdown-item text-danger"
                                            onclick="deleteGroupMessage(@message.Id)">

                                        Delete

                                    </button>

                                </li>

                            </ul>

                        </div>
                    }

                    @if (message.IsDeleted)
                    {
                        <i class="bi bi-trash text-danger"></i>

                        <em class="text-muted">
                            This message was deleted
                        </em>
                    }
                    else
                    {
                        @message.Content

                        <br />

                        <small>
                            @message.SentAt.ToString("hh:mm tt")
                        </small>
                    }

                </div>

            </div>
        }

    </div>

    <div class="chat-footer">

        <input type="hidden"
               id="roomName"
               value="@Model.Room.Name" />

        <div class="input-group">

            <input id="txtMessage"
                   class="form-control"
                   placeholder="Type message..." />

            <button class="btn btn-primary"
                    onclick="sendGroupMessage()">

                Send

            </button>

        </div>

    </div>

</div>

@section Scripts {

    <script>

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();
            connection.on("ReceiveRoomMessage", function (user, message, sentAt)
            {
            let myName = '@User.Identity!.Name?.Split("@")[0]';
            let mine = user === myName;
            let html=`
                <div class="message-row ${mine ? "my-message":"friend-message"}">

                    <div class="message-box">

                        ${mine ? "" : `<strong>${user}</strong><br>`}

                        ${message}

                        <br>

                        <small>
                            ${new Date(sentAt).toLocaleTimeString([],{
                                hour:'2-digit',
                                minute:'2-digit'
                            })}
                        </small>

                    </div>

                </div>
            `;

            chatBody.insertAdjacentHTML("beforeend",html);

            chatBody.scrollTop=chatBody.scrollHeight;
        });
        connection.on("GroupMessageDeleted", function(messageId)
        {
            let msg=document.getElementById("msg-"+messageId);

            if(!msg)
                return;

            msg.innerHTML=`
                <i class="bi bi-trash text-danger"></i>
                <em class="text-muted">
                    This message was deleted
                </em>
            `;
        });


        connection.start().then(function(){

            connection.invoke(
                "JoinRoom",
                document.getElementById("roomName").value);

        });

        async function sendGroupMessage()
        {
            let room=document.getElementById("roomName").value;

            let msg=document.getElementById("txtMessage").value.trim();

            if(msg=="")
                return;

            await connection.invoke(
                "SendMessageToRoom",
                room,
                msg);

            txtMessage.value="";
        }

        async function deleteGroupMessage(messageId)
        {
            if(!confirm("Delete this message?"))
                return;

            await connection.invoke(
                "DeleteGroupMessage",
                messageId);
        }

    </script>

}