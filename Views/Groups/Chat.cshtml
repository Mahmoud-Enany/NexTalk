@model SignalRTask.ViewModels.Groups.GroupChatVM

@{
    ViewData["Title"] = Model.Room.Name;
}

<div class="chat-container">

    <div class="chat-header">

        <div>

            <h4 class="mb-0">
                @Model.Room.Name
            </h4>

            <input type="hidden"
                   id="roomId"
                   value="@Model.Room.Id" />

            <small class="text-muted">

                @Model.MembersCount Members

            </small>

            <br />

            <small id="onlineCount"
                   class="text-success">

                🟢 @Model.OnlineUsers.Count Online

            </small>

            @if (Model.OnlineUsers.Any())
            {
                <div id="onlineUsers"
                     class="mt-2">

                    @foreach (var user in Model.OnlineUsers)
                    {
                        <span class="badge bg-success me-1">

                            @user

                        </span>
                    }

                </div>
            }

        </div>

        <a asp-action="Index"
           class="btn btn-light btn-sm">

            Back

        </a>

    </div>

    <div class="chat-body" id="chatBody">

        @foreach (var message in Model.Messages)
        {
            bool mine = message.SenderId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

            <div class="message-row @(mine ? "my-message" : "friend-message")">

                <div class="message-box position-relative" id="msg-@message.Id">

                    @if (!mine)
                    {
                        <strong>@message.Sender.UserName?.Split('@')[0]</strong>
                        <br />
                    }

                    @if (mine && !message.IsDeleted)
                    {
                        <div class="dropdown position-absolute top-0 end-0">

                            <button class="btn btn-sm border-0 text-white"
                                    data-bs-toggle="dropdown">

                                ⋮

                            </button>

                            <ul class="dropdown-menu">

                                <li>

                                    <button class="dropdown-item"
                                            onclick="editGroupMessage(@message.Id)">

                                        Edit

                                    </button>

                                </li>

                                <li>

                                    <button class="dropdown-item text-danger"
                                            onclick="deleteGroupMessage(@message.Id)">

                                        Delete

                                    </button>

                                </li>

                            </ul>

                        </div>
                    }

                    @if (message.IsDeleted)
                    {
                        <i class="bi bi-trash text-danger"></i>

                        <em class="text-muted">
                            This message was deleted
                        </em>
                    }
                    else
                    {
                        <span class="message-content">

                            @message.Content

                        </span>

                        <br />

                        <small>

                            @message.SentAt.ToString("hh:mm tt")

                            @if (message.IsEdited)
                            {
                                <span class="text-muted">(edited)</span>
                            }

                        </small>
                    }

                </div>

            </div>
        }

    </div>

    <div class="chat-footer">

        <input type="hidden"
               id="roomName"
               value="@Model.Room.Name" />

        <div class="input-group">

            <input id="txtMessage"
                   class="form-control"
                   placeholder="Type message..." />

            <button class="btn btn-primary"
                    onclick="sendGroupMessage()">

                Send

            </button>

        </div>

    </div>

</div>

@section Scripts {

    <script>

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        connection.on("ReceiveRoomMessage", function (messageId, senderId, user, message, sentAt)
        {
            let myId='@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value';

            let mine = senderId === myId;

            let html=`
                <div class="message-row ${mine ? "my-message":"friend-message"}">

                    <div class="message-box position-relative" id="msg-${messageId}">

                        ${
                            mine
                            ?
                            `
                            <div class="dropdown position-absolute top-0 end-0">

                                <button class="btn btn-sm border-0 text-white"
                                        data-bs-toggle="dropdown">

                                    ⋮

                                </button>

                                <ul class="dropdown-menu">

                                    <li>

                                        <button class="dropdown-item"
                                                onclick="editGroupMessage(${messageId})">

                                            Edit

                                        </button>

                                    </li>

                                    <li>

                                        <button class="dropdown-item text-danger"
                                                onclick="deleteGroupMessage(${messageId})">

                                            Delete

                                        </button>

                                    </li>

                                </ul>

                            </div>
                            `
                            :
                            `<strong>${user}</strong><br>`
                        }

                        <span class="message-content">

                            ${message}

                        </span>

                        <br>

                        <small>

                            ${new Date(sentAt).toLocaleTimeString([],{
                                hour:'2-digit',
                                minute:'2-digit'
                            })}

                        </small>

                    </div>

                </div>
            `;

            chatBody.insertAdjacentHTML("beforeend",html);

            chatBody.scrollTop=chatBody.scrollHeight;
        });

        connection.on("GroupMessageDeleted", function(messageId)
        {
            let msg=document.getElementById("msg-"+messageId);

            if(!msg)
                return;

            msg.innerHTML=`
                <i class="bi bi-trash text-danger"></i>
                <em class="text-muted">
                    This message was deleted
                </em>
            `;
        });

        connection.on("GroupMessageEdited", function(messageId,newContent){

            let box=document.querySelector("#msg-"+messageId+" .message-content");

            if(box)
            {
                box.innerHTML=newContent;
            }

            let small=document.querySelector("#msg-"+messageId+" small");

            if(small && !small.innerHTML.includes("(edited)"))
            {
                small.innerHTML += ' <span class="text-muted">(edited)</span>';
            }

        });

        connection.on("GroupOnlineUsersChanged",function(){

            refreshOnlineMembers();

        });


        connection.start().then(async function(){

            await connection.invoke(
                "JoinRoom",
                document.getElementById("roomName").value);

            refreshOnlineMembers();

        });

        async function sendGroupMessage()
        {
            let room=document.getElementById("roomName").value;

            let msg=document.getElementById("txtMessage").value.trim();

            if(msg=="")
                return;

            await connection.invoke(
                "SendMessageToRoom",
                room,
                msg);

            txtMessage.value="";
        }

        async function deleteGroupMessage(messageId)
        {
            if(!confirm("Delete this message?"))
                return;

            await connection.invoke(
                "DeleteGroupMessage",
                messageId);
        }

        async function editGroupMessage(messageId)
        {
            let current=document.querySelector("#msg-"+messageId+" .message-content").innerText;

            let text=prompt("Edit message",current);

            if(text===null)
                return;

            if(text.trim()==="")
                return;

            await connection.invoke(
                "EditGroupMessage",
                messageId,
                text);
        }

        async function refreshOnlineMembers()
        {
            let roomId=document.getElementById("roomId").value;

            let response=await fetch("/Groups/GetOnlineMembers?roomId="+roomId);

            let users=await response.json();

            document.getElementById("onlineCount").innerHTML=
                `🟢 ${users.length} Online`;

            let div=document.getElementById("onlineUsers");

            div.innerHTML="";

            users.forEach(function(user)
            {
                div.innerHTML+=
                `<span class="badge bg-success me-1">
                    ${user}
                </span>`;
            });
        }

    </script>

}