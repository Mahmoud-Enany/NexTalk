@model List<SignalRTask.Models.Rooms>

@{
    ViewData["Title"] = "My Groups";
}

<div class="container mt-5">

    <div class="mb-4">

        <h2 class="fw-bold">
            👥 My Groups
        </h2>

        <p class="text-muted">
            Join your favorite communities and collaborate with your teammates in real-time.
        </p>

    </div>

    @if (!Model.Any())
    {
        <div class="card shadow-sm">

            <div class="card-body text-center py-5">

                <i class="bi bi-people display-1 text-secondary"></i>

                <h4 class="mt-3">
                    No Groups Yet
                </h4>

                <p class="text-muted">
                    You haven't joined any groups yet.
                </p>

                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-primary">

                    Go to Home

                </a>

            </div>

        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var group in Model)
            {
                <div class="col-lg-4 col-md-6">

                    <div class="card h-100 shadow-sm group-card">

                        <div class="card-body d-flex flex-column">

                            <div class="mb-3">

                                <h4 class="fw-bold">

                                    <i class="bi bi-folder2-open text-primary"></i>

                                    @group.Name

                                </h4>

                                <p class="text-muted mb-2">

                                    <i class="bi bi-people-fill"></i>

                                    @group.Members.Count Members

                                </p>

                                @if (group.Messages.Any())
                                {
                                    var lastMessage = group.Messages
                                    .OrderByDescending(x => x.SentAt)
                                    .First();

                                    <div class="border-top pt-2">

                                        <small class="text-muted d-block">

                                            <i class="bi bi-clock-history"></i>

                                            Last message

                                        </small>

                                        <small>

                                            <strong>

                                                @(lastMessage.Sender.UserName?.Split('@')[0])

                                            </strong>

                                            :

                                            @(lastMessage.IsDeleted
                                                                            ? "This message was deleted"
                                                                            : lastMessage.Content.Length > 25
                                                                            ? lastMessage.Content.Substring(0, 25) + "..."
                                                                            : lastMessage.Content)

                                        </small>

                                    </div>
                                }
                                else
                                {
                                    <div class="border-top pt-2">

                                        <small class="text-muted">

                                            No messages yet

                                        </small>

                                    </div>
                                }

                            </div>

                            <div class="mt-auto">

                                <a asp-controller="Groups"
                                   asp-action="Chat"
                                   asp-route-id="@group.Id"
                                   class="btn btn-primary w-100">

                                    <i class="bi bi-chat-dots-fill"></i>

                                    Open Chat

                                </a>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

<style>

    .group-card {
        transition: .25s ease;
        border: none;
    }

        .group-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 35px rgba(0,0,0,.15) !important;
        }

</style>