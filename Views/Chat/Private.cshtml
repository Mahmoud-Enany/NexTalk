@model SignalRTask.ViewModels.Chat.PrivateChatVM

@{
    ViewData["Title"] = "Private Chat";
}

<div class="chat-container">

    <div class="chat-header">

        <div class="chat-user">

            <i class="bi bi-person-circle"></i>

            <div>

                <h5>@Model.Friend.Email</h5>

                <small id="userStatus">
                    Offline
                </small>

            </div>

        </div>

        <a asp-controller="Friends"
           asp-action="Index"
           class="btn btn-light btn-sm">
            Back
        </a>

    </div>

    <div class="chat-body" id="chatBody">

        @foreach (var message in Model.Messages)
        {
            bool mine = message.SenderId == (string)ViewBag.CurrentUserId;

            <div class="message-row @(mine ? "my-message" : "friend-message")">

                <div class="message-box" id="msg-@message.Id">

                    @message.Content

                    <br />

                    <small>

                        @message.SentAt.ToString("hh:mm tt")

                        @if (mine)
                        {
                            <span class="delivery @(message.IsSeen ? "seen" : "")">

                                @(message.IsDelivered ? "✓✓" : "✓")

                            </span>
                        }

                    </small>

                </div>

            </div>
        }

    </div>
    <div id="typingIndicator"
         class="text-muted ps-3 pb-2"
         style="display:none;font-style:italic;">
    </div>
    <div class="chat-footer">

        <input type="hidden" id="friendId" value="@Model.FriendId" />

        <div class="input-group">

            <span class="input-group-text">

                <i class="bi bi-emoji-smile"></i>

            </span>

            <input id="txtMessage"
                   class="form-control"
                   placeholder="Type your message..." />

            <button type="button"
                    class="btn btn-primary"
                    onclick="sendMessage()">

                <i class="bi bi-send-fill"></i>

                Send

            </button>

        </div>

    </div>

</div>

@section Scripts
{
    <script>
        let typingTimeout;
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

                connection.on("ReceivePrivateChatMessage",
        function(messageId,senderId,senderName,message,sentAt){

            let myId='@ViewBag.CurrentUserId';

            let mine=senderId===myId;

            let checks=mine?"<span class='delivery'>✓</span>":"";

            let html=`

                <div class="message-row ${mine?"my-message":"friend-message"}">

                    <div class="message-box" id="msg-${messageId}">

                        ${message}

                        <br>

                        <small>

                            ${new Date(sentAt).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'})}

                            ${checks}

                        </small>

                    </div>

                </div>
            `;

            chatBody.insertAdjacentHTML("beforeend",html);

            chatBody.scrollTop=chatBody.scrollHeight;

            if (!mine) {

                connection.invoke("MarkMessageDelivered", messageId);

            }

        });

        connection.on("MessageDelivered",function(messageId){

            let msg=document.querySelector(`#msg-${messageId} .delivery`);

            if(msg){

                msg.innerHTML="✓✓";

            }

        });
        connection.on("MessageSeen", function (messageId) {
            let msg = document.querySelector(`#msg-${messageId} .delivery`);
            if (msg)
            {
                msg.innerHTML = "✓✓";
                msg.classList.add("seen");
            }
        });
        connection.on("UserTyping", function (senderName) {
            let div = document.getElementById("typingIndicator");
            div.innerHTML = senderName + " is typing...";
            div.style.display = "block";
            clearTimeout(typingTimeout);
            typingTimeout = setTimeout(function () 
            {
                div.style.display = "none";
            }, 1500);

        });
        connection.on("UserOnline", function (userId) 
        {
            let friendId = document.getElementById("friendId").value;
            if (friendId === userId) 
            {
                document.getElementById("userStatus").innerHTML = "🟢 Online";
            }
        });

        connection.on("UserOffline", function (userId) {
            let friendId = document.getElementById("friendId").value;
            if (friendId === userId) {
                document.getElementById("userStatus").innerHTML = "⚫ Offline";
            }
        });

        connection.start().then(async () => 
        { 
            document.querySelectorAll(".friend-message .message-box").forEach(function (item) {
                let id = item.id.replace("msg-", "");
                connection.invoke("MarkMessageSeen", parseInt(id));
            });

            let friendId = document.getElementById("friendId").value;
            let online = await connection.invoke("IsUserOnline", friendId);
            document.getElementById("userStatus").innerHTML = online ? "🟢 Online" : "⚫ Offline";
        });

        document.getElementById("txtMessage").addEventListener("input", function () {
            let receiverId = document.getElementById("friendId").value;
            connection.invoke("Typing", receiverId);
        });

        async function sendMessage(){
            let receiverId=document.getElementById("friendId").value;
            let message=document.getElementById("txtMessage").value.trim();
            if(message==="")
                return;
            await connection.invoke(
                "SendPrivateChatMessage",
                receiverId,
                message);

            txtMessage.value="";

        }

    </script>
}