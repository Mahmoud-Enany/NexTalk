@model SignalRTask.ViewModels.HomeVM

@{
    ViewData["Title"] = "Rooms";
}

<div class="container mt-5">

    <div class="card shadow">

        <div class="card-header bg-primary text-white py-4">

            <h2 class="mb-1">

                Welcome back,
                @User.Identity?.Name?.Split('@')[0]
                👋

            </h2>

            <p class="mb-0 opacity-75">

                Manage your rooms and collaborate with your teammates in real-time.

            </p>

        </div>

        <div class="card-body">


            <div class="row mb-4">

                <div class="col-md-3">

                    <div class="card text-center border-0 shadow h-100">

                        <div class="card-body">

                            <i class="bi bi-people-fill text-primary fs-2"></i>

                            <h3>@Model.FriendsCount</h3>

                            <p class="mb-0">Friends</p>

                        </div>

                    </div>

                </div>

                <div class="col-md-3">

                    <div class="card text-center border-success shadow-sm">

                        <div class="card-body">

                            <i class="bi bi-diagram-3-fill text-success fs-2"></i>

                            <h3>@Model.RoomsCount</h3>

                            <p class="mb-0">Rooms</p>

                        </div>

                    </div>

                </div>

                <div class="col-md-3">

                    <div class="card text-center border-warning shadow-sm">

                        <div class="card-body">

                            <i class="bi bi-chat-dots-fill text-warning fs-2"></i>

                            <h3>@Model.MessagesCount</h3>

                            <p class="mb-0">Messages</p>

                        </div>

                    </div>

                </div>

                <div class="col-md-3">

                    <div class="card text-center border-info shadow-sm">

                        <div class="card-body">

                            <i class="bi bi-wifi text-info fs-2"></i>

                            <h3>@Model.OnlineUsersCount</h3>

                            <p class="mb-0">Online</p>

                        </div>

                    </div>

                </div>

            </div>

            <hr />


            <div class="row g-2">

                <div class="col-md-9">

                    <input type="text"
                           id="roomName"
                           class="form-control"
                           placeholder="Enter Room Name..." />

                </div>

                <div class="col-md-3">

                    <button onclick="CreateRoom()"
                            class="btn btn-success w-100">

                        Create Room

                    </button>

                </div>

            </div>

            <hr />


            <h5 class="mb-3">Available Rooms</h5>

            <div class="row g-2">

                <div class="col-md-9">

                    <select id="roomsSelect"
                            class="form-select">

                        @foreach (var room in Model.Rooms)
                        {
                            <option value="@room.Id">
                                @room.Name
                            </option>
                        }

                    </select>

                </div>

                <div class="col-md-3">

                    <button onclick="JoinRoom()"
                            class="btn btn-primary w-100">

                        Join Room

                    </button>

                </div>

            </div>

            <div class="mt-3 text-muted">

                Total Rooms :
                <span id="roomsCount">
                    @Model.Rooms.Count
                </span>

            </div>

            <hr />


            <h5>Activity Log</h5>

            <ul id="activityLog"
                class="list-group">
            </ul>

        </div>

    </div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>

<script>

    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/chatHub")
        .build();

    connection.start();

    function CreateRoom()
    {
        let roomName=document.getElementById("roomName").value;

        connection.invoke("CreateRoom",roomName);
    }

    function JoinRoom()
    {
        let roomName=document.getElementById("roomsSelect").selectedOptions[0].text;

        connection.invoke("JoinRoom",roomName);

        window.location.href="/Groups/Chat/"+document.getElementById("roomsSelect").value;
    }

    connection.on("RoomCreated",function(id,roomName,user)
    {
        document.getElementById("roomsSelect").innerHTML+=
            `<option value="${id}">${roomName}</option>`;

        document.getElementById("roomsCount").innerText=
            document.getElementById("roomsSelect").options.length;

        document.getElementById("activityLog").innerHTML=
            `<li class="list-group-item">${user} created room ${roomName}</li>`
            +document.getElementById("activityLog").innerHTML;

        document.getElementById("roomName").value="";
    });

    connection.on("UserJoinedRoom",function(user,roomName)
    {
        document.getElementById("activityLog").innerHTML=
            `<li class="list-group-item">${user} joined room ${roomName}</li>`
            +document.getElementById("activityLog").innerHTML;
    });

</script>